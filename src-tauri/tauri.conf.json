{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Crossover Mod Manager",
  "version": "0.1.0",
  "identifier": "com.beneccles.crossover-mod-manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Crossover Mod Manager",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      },
      "capabilities": [
        {
          "identifier": "main-capability",
          "description": "Main application permissions",
          "windows": ["main"],
          "permissions": [
            "core:default",
            "dialog:allow-open",
            "dialog:allow-save",
            "dialog:allow-message",
            "dialog:allow-ask",
            "dialog:allow-confirm",
            "fs:allow-read-text-file",
            "fs:allow-write-text-file",
            "fs:allow-read-file",
            "fs:allow-write-file",
            "fs:allow-read-dir",
            "fs:allow-exists",
            "fs:allow-remove",
            "fs:allow-mkdir",
            "fs:allow-copy-file",
            "http:default",
            "shell:allow-open",
            "deep-link:default"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Nexus Mod Manager for CrossOver",
    "longDescription": "A mod manager for PC games on Mac via CrossOver, with NexusMods integration for seamless mod installation.",
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-"
    },
    "iOS": {},
    "android": {}
  },
  "plugins": {
    "deep-link": {
      "schemes": ["nxm"]
    }
  }
}
